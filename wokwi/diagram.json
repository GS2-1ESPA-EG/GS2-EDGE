{
  "version": 1,
  "author": "Enrico Dellatorre RM566824, Gustavo Hiruo RM567625",
  "editor": "wokwi",
  "parts": [
    {
      "type": "board-esp32-devkit-c-v4",
      "id": "esp",
      "top": 0,
      "left": 0,
      "attrs": {}
    },
    {
      "type": "wokwi-dht22",
      "id": "dht1",
      "top": -90,
      "left": 200,
      "attrs": { "temperature": "5", "humidity": "50" }
    },
    {
      "type": "wokwi-mpu6050",
      "id": "imu1",
      "top": 100,
      "left": 200,
      "attrs": {}
    },
    {
      "type": "wokwi-ldr-sensor",
      "id": "ldr1",
      "top": -50,
      "left": -180,
      "attrs": {}
    },
    {
      "type": "wokwi-led",
      "id": "led1",
      "top": 60,
      "left": -160,
      "attrs": { "color": "red" }
    },
    {
      "type": "wokwi-buzzer",
      "id": "bz1",
      "top": 200,
      "left": -150,
      "attrs": {}
    },
    {
      "type": "wokwi-resistor",
      "id": "r1",
      "top": 80,
      "left": -110,
      "attrs": { "value": "220" }
    }
  ],
  "connections": [
    [ "esp:TX",  "$serialMonitor:RX", "", [] ],
    [ "esp:RX",  "$serialMonitor:TX", "", [] ],

    [ "dht1:VCC", "esp:3V3", "red", [ "v0" ] ],
    [ "dht1:GND", "esp:GND.1", "black", [ "v0" ] ],
    [ "dht1:SDA", "esp:15", "green", [ "v0" ] ],

    [ "imu1:VCC", "esp:3V3", "red", [ "v0" ] ],
    [ "imu1:GND", "esp:GND.2", "black", [ "v0" ] ],
    [ "imu1:SDA", "esp:21", "green", [ "v0" ] ],
    [ "imu1:SCL", "esp:22", "blue", [ "v0" ] ],

    [ "ldr1:VCC", "esp:3V3", "red", [ "v0" ] ],
    [ "ldr1:GND", "esp:GND.3", "black", [ "v0" ] ],
    [ "ldr1:AO",  "esp:34", "yellow", [ "v0" ] ],

    [ "led1:A", "r1:1", "green", [ "v0" ] ],
    [ "r1:2",   "esp:2", "green", [ "v0" ] ],
    [ "led1:C", "esp:GND.1", "black", [ "v0" ] ],

    [ "bz1:1", "esp:4", "green", [ "v0" ] ],
    [ "bz1:2", "esp:GND.2", "black", [ "v0" ] ]
  ],
  "dependencies": {},
  "serialMonitor": { "display": "always" }
}
